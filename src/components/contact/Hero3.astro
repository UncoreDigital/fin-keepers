<div
  class="main-container bg-[#f5f7fa] w-full px-4 sm:px-6 lg:px-8 py-12 mt-20"
>
  <div
    class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center justify-center"
  >
    <div class="flex flex-col gap-6 lg:gap-12">
      <div class="flex flex-col gap-3">
        <h1
          class="font-['Inter'] text-[30px] sm:text-[52px] font-bold leading-[40.4px] sm:leading-[62.4px] text-[#151515]"
        >
          Secure your firm's future.
        </h1>
        <span
          class="font-['Inter'] text-[18px] font-normal leading-[27px] text-[#797979]"
        >
          Ready to take your business to the next level? Let Finkeepers handle
          your bookkeeping so you can focus on growing stronger and smarter.
          Connect with us today to see how we help you gain financial clarity
          and fuel your growth.
        </span>
      </div>

      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div
            class="w-[20px] h-[20px] flex-shrink-0 flex items-center justify-center"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                fill="#ed7c00"></path>
            </svg>
          </div>
          <a
            href="tel:+14083702711"
            class="font-['Inter'] text-[16px] font-normal leading-[19px] text-[#797979] hover:text-[#ed7c00] transition-colors cursor-pointer"
          >
            +1-408-370-2711
          </a>
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-[22px] h-[17px] bg-[url(https://codia-f2c.s3.us-west-1.amazonaws.com/image/2025-08-13/px0gYmJunj.png)] bg-cover bg-no-repeat"
          >
          </div>
          <a
            href="https://mail.google.com/mail/?view=cm&to=hi@finkeepers.us"
            target="_blank"
            rel="noopener noreferrer"
            class="font-['Inter'] text-[16px] font-normal leading-[19px] text-[#797979] hover:text-[#ed7c00] transition-colors cursor-pointer"
          >
            hi@finkeepers.us
          </a>
        </div>
        <!-- <div class="flex items-center gap-4">
          <div
            class="w-[22px] h-[22px] bg-[url(https://codia-f2c.s3.us-west-1.amazonaws.com/image/2025-08-13/dq8Qp3xLYT.png)] bg-cover bg-no-repeat"
          >
          </div>
          <span
            class="font-['Inter'] text-[16px] font-normal leading-[19px] text-[#797979]"
          >
            + 123 456 789
          </span>
        </div> -->
        <div class="flex items-start gap-4">
          <div
            class="w-[20px] h-[24px] bg-[url(https://codia-f2c.s3.us-west-1.amazonaws.com/image/2025-08-13/XPK7JNWOVH.png)] bg-cover bg-no-repeat"
          >
          </div>
          <span
            class="font-['Inter'] text-[16px] font-normal leading-[19.364px] text-[#797979] w-[296px]"
          >
            <a
              href="https://www.google.com/maps/search/?api=1&query=30+N+Gould+ST+STE+R,+Sheridan,+Wyoming,+82801"
              target="_blank"
              rel="noopener noreferrer"
            >
              30 N Gould ST STE R, Sheridan, Wyoming, 82801 United States
            </a>
          </span>
        </div>
      </div>
    </div>

    <form
      class="flex flex-col gap-6 p-5 bg-[#fff] rounded-[16px] shadow-[0_1px_11.1px_0_rgba(237,124,0,0.16)]"
    >
      <div class="flex flex-col gap-3">
        <span
          class="font-['Inter'] text-[36px] font-semibold leading-[43.568px] text-[#04092a]"
        >
          Get in Touch
        </span>
        <span
          class="font-['Inter'] text-[16px] font-medium leading-[22px] text-[#797979]"
        >
          We’re here to assist you.
        </span>
      </div>

      <div class="flex flex-col gap-4">
        <label for="fullname" class="sr-only">Full Name</label>
        <input
          type="text"
          id="fullname"
          placeholder="Full Name"
          class="h-[52px] rounded-[25px] border border-[#d0d5dd] overflow-hidden px-6 placeholder-[#797979] text-[15px] font-normal font-['Inter'] focus:outline-none focus:border-[#ed7c00]"
        />

        <label for="email" class="sr-only">Email Address</label>
        <input
          type="email"
          id="email"
          placeholder="Email Address"
          class="h-[52px] rounded-[25px] border border-[#d0d5dd] overflow-hidden px-6 placeholder-[#797979] text-[15px] font-normal font-['Inter'] focus:outline-none focus:border-[#ed7c00]"
        />

        <label for="message" class="sr-only">Message</label>
        <textarea
          id="message"
          placeholder="Message"
          rows="4"
          class="h-[107px] rounded-[25px] border border-[#d0d5dd] overflow-hidden pt-4 px-6 placeholder-[#797979] text-[15px] font-normal font-['Inter'] focus:outline-none focus:border-[#ed7c00] resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="h-[50px] bg-[#ed7c00] rounded-[8px] flex items-center justify-center px-6 text-[#fff] font-['Inter'] text-[18px] font-semibold leading-[24px] hover:bg-[#d66a00] transition-colors duration-300"
      >
        Submit
      </button>

      <!-- Thank You Message -->
      <div
        id="thank-you-message"
        class="hidden flex-col gap-4 p-6 bg-[#106253] rounded-[16px] border border-[#106253] shadow-[0_1px_11.1px_0_rgba(16,98,83,0.16)] text-center"
      >
        <div class="flex items-center justify-center mb-2">
          <svg
            class="w-12 h-12 text-white"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
              clip-rule="evenodd"></path>
          </svg>
        </div>
        <span
          class="font-['Inter'] text-[24px] font-semibold leading-[30px] text-white"
        >
          Thank you!
        </span>
        <span
          class="font-['Inter'] text-[16px] font-normal leading-[22px] text-white"
        >
          Your form has been successfully submitted.<br />
          Our team will get back to you shortly.
        </span>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.querySelector("form") as HTMLFormElement;
    const thankYouMessage = document.getElementById("thank-you-message");
    const submitButton = form
      ? (form.querySelector('button[type="submit"]') as HTMLButtonElement)
      : null;

    // Helper to show custom toast
    const showToast = (message: string, type = "success") => {
      const toast = document.createElement("div");
      toast.textContent = message;

      const bgColor = type === "success" ? "#ed7c00" : "#ef4444";
      toast.style.cssText = `
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background-color: ${bgColor};
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        font-size: 16px;
        z-index: 9999;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      `;

      document.body.appendChild(toast);

      // Animate in
      requestAnimationFrame(() => {
        toast.style.transform = "translateX(-50%) translateY(0)";
      });

      // Remove after 3.5s
      setTimeout(() => {
        toast.style.transform = "translateX(-50%) translateY(100px)";
        setTimeout(() => toast.remove(), 300);
      }, 3500);
    };

    if (form && thankYouMessage && submitButton) {
      form.addEventListener("submit", async function (e) {
        e.preventDefault();

        // Get form inputs
        const fullNameInput = form.querySelector(
          "#fullname",
        ) as HTMLInputElement;
        const emailInput = form.querySelector("#email") as HTMLInputElement;
        const messageInput = form.querySelector(
          "#message",
        ) as HTMLTextAreaElement;

        const fullName = fullNameInput ? fullNameInput.value.trim() : "";
        const email = emailInput ? emailInput.value.trim() : "";
        const message = messageInput ? messageInput.value.trim() : "";

        // Basic validation
        if (!fullName || !email || !message) {
          showToast("Please fill in all fields.", "error");
          return;
        }

        // Show loading state
        const originalText = submitButton.textContent || "Submit";
        const originalOpacity = submitButton.style.opacity || "1";
        const originalCursor = submitButton.style.cursor || "";

        submitButton.textContent = "Sending...";
        submitButton.disabled = true;
        submitButton.style.opacity = "0.7";
        submitButton.style.cursor = "not-allowed";

        const htmlBody = `
          <div style="font-family: Arial, sans-serif; max-w: 600px; margin: 0 auto;">
            <h2 style="color: #ed7c00;">New Contact Submission</h2>
            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
              <tbody>
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left; width: 35%;">Name</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${fullName}</td>
                </tr>
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left;">Email</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${email}</td>
                </tr>
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left; vertical-align: top;">Message</th>
                  <td style="border: 1px solid #ddd; padding: 12px; white-space: pre-wrap;">${message}</td>
                </tr>
              </tbody>
            </table>
          </div>
        `;

        const payload = {
          source: "Finkeepers Contact Page",
          htmlBody: htmlBody,
        };

        try {
          const response = await fetch(
            "https://script.google.com/macros/s/AKfycbxij8BcsGQ7-hN7qUHlYXE5CbJiFO16LkOrAEAwbon5tN1A_oCDOFH91ehZoVdFsRFQ/exec",
            {
              method: "POST",
              body: JSON.stringify(payload),
            },
          );

          if (!response.ok) {
            throw new Error("Failed to send submission");
          }

          // Hide form inputs
          const formInputs = form.querySelectorAll("input, textarea, button");
          formInputs.forEach((input) => {
            if (input !== submitButton) {
              (input as HTMLElement).style.display = "none";
            }
          });

          // Hide the title and description
          const formHeader = form.querySelector(
            ".flex.flex-col.gap-3",
          ) as HTMLElement;
          if (formHeader) {
            formHeader.style.display = "none";
          }

          // Hide the input container
          const inputContainer = form.querySelector(
            ".flex.flex-col.gap-4",
          ) as HTMLElement;
          if (inputContainer) {
            inputContainer.style.display = "none";
          }

          // Hide submit button
          submitButton.style.display = "none";

          // Show thank you message
          thankYouMessage.classList.remove("hidden");
          thankYouMessage.classList.add("flex");

          showToast("Thank you! Your message has been sent.", "success");

          // Reset form after 5 seconds
          setTimeout(() => {
            // Reset form
            form.reset();

            // Show form elements again
            formInputs.forEach((input) => {
              (input as HTMLElement).style.display = "";
            });

            if (formHeader) {
              formHeader.style.display = "";
            }

            if (inputContainer) {
              inputContainer.style.display = "";
            }

            submitButton.style.display = "";
            submitButton.textContent = originalText;
            submitButton.disabled = false;

            // Hide thank you message
            thankYouMessage.classList.add("hidden");
            thankYouMessage.classList.remove("flex");

            // Re-enable in case we need it
            submitButton.disabled = false;
            submitButton.textContent = originalText;
            submitButton.style.opacity = originalOpacity;
            submitButton.style.cursor = originalCursor;
          }, 5000);
        } catch (error) {
          console.error("Submission Error:", error);
          showToast("Submission failed. Please try again later.", "error");

          // Reset button state immediately on error
          submitButton.disabled = false;
          submitButton.textContent = originalText;
          submitButton.style.opacity = originalOpacity;
          submitButton.style.cursor = originalCursor;
        }
      });
    }
  });
</script>
