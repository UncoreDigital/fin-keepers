<div
  id="contact-section"
  class="main-container w-full min-h-[622px] z-[50] relative mx-auto my-0 px-4 py-10 lg:py-0 cta"
  id="contact-form"
>
  <div
    class="max-w-[1320px] mx-auto h-auto lg:h-[675px] bg-[#106253] rounded-[20px] lg:rounded-[30px] relative flex flex-col lg:flex-row items-center justify-between px-6 lg:px-12 py-2 lg:pt-12 lg:pb-8"
  >
    <!-- Mobile Layout: Text Content First -->
    <div class="w-full lg:hidden flex flex-col gap-4 mt-[20px] order-1">
      <h2
        class="text-[28px] sm:text-[32px] font-bold leading-tight text-white font-['Inter']"
      >
        If You Are Ready To Trust Us, Let's Grow Together...
      </h2>
      <p
        class="text-[16px] font-normal leading-relaxed text-white/90 font-['Inter']"
      >
        Ready for stress-free bookkeeping and smarter financial decisions?
        Connect with your Finkeepers pod now.
      </p>
    </div>

    <!-- Mobile Layout: Form Second -->
    <div class="w-full lg:hidden flex justify-center order-2 mt-6">
      <div class="w-full max-w-[390px] mx-auto flex flex-col h-full">
        <!-- Form Container -->
        <div class="flex-1 flex flex-col justify-center">
          <form id="contact-form-submit-mobile" class="flex flex-col gap-6">
            <!-- Name -->
            <div class="relative w-full">
              <input
                type="text"
                name="name"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Name"
              />
            </div>

            <!-- Email -->
            <div class="relative w-full">
              <input
                type="email"
                name="email"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Email"
              />
            </div>

            <!-- Company Name -->
            <div class="relative w-full">
              <input
                type="text"
                name="company"
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Company Name"
              />
            </div>

            <!-- Message -->
            <div class="relative w-full">
              <textarea
                name="message"
                rows="3"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 resize-none text-left"
                placeholder="Message"></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="bg-[#ed7c00] text-white font-semibold text-[18px] font-['Inter'] rounded-[8px] py-[14px] px-[30px] w-full border border-transparent hover:bg-[#d66a00] transition-colors duration-300 mt-4"
            >
              Talk to our Experts
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Mobile Layout: Illustration Third (Bottom) -->
    <div class="w-full lg:hidden flex justify-center order-3 mt-4 -mb-10">
      <div
        class="w-full max-w-[480px] h-[300px] bg-[url('/src/assets/new_contact.png')] bg-contain bg-no-repeat bg-center relative top-[10px]"
      >
      </div>
    </div>

    <!-- Desktop Layout: Left Side - Content and Illustration -->
    <div class="hidden lg:flex w-full lg:w-1/2 flex-col gap-0">
      <!-- Text Content -->
      <div id="left-content" class="flex flex-col gap-4 mt-[60px]">
        <h2
          class="text-[28px] sm:text-[32px] md:text-[36px] lg:text-[42px] font-bold leading-tight text-white font-['Inter']"
        >
          If You Are Ready To Trust Us, Let's Grow Together...
        </h2>
        <p
          class="text-[18px] font-normal leading-relaxed text-white/90 font-['Inter']"
        >
          Ready for stress-free bookkeeping and <br />smarter financial
          decisions? Connect with <br />your Finkeepers pod now.
        </p>
      </div>

      <!-- Illustration -->
      <div
        id="illustration"
        class="flex justify-center lg:justify-start mt-[60px]"
      >
        <div
          class="w-full max-w-[480px] h-[300px] sm:h-[360px] lg:h-[420px] bg-[url('/src/assets/new_contact.png')] bg-contain bg-no-repeat bg-center"
        >
        </div>
      </div>
    </div>

    <!-- Desktop Layout: Right Side - Form -->
    <div
      class="hidden lg:flex w-full lg:w-1/2 lg:pl-8 mt-8 lg:mt-0 justify-center"
    >
      <div class="w-full max-w-[390px] mx-auto flex flex-col h-full">
        <!-- Form Container -->
        <div class="flex-1 flex flex-col justify-center">
          <form id="contact-form-submit" class="flex flex-col gap-6">
            <!-- Name -->
            <div class="relative w-full">
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Name"
              />
            </div>

            <!-- Email -->
            <div class="relative w-full">
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Email"
              />
            </div>

            <!-- Company Name -->
            <div class="relative w-full">
              <input
                type="text"
                id="company"
                name="company"
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 text-left"
                placeholder="Company Name"
              />
            </div>

            <!-- Message -->
            <div class="relative w-full">
              <textarea
                id="message"
                name="message"
                rows="3"
                required
                class="w-full bg-transparent border-b-2 border-white/30 text-white py-3 px-0 outline-none font-['Inter'] placeholder:text-white/60 focus:border-white transition-colors duration-300 resize-none text-left"
                placeholder="Message"></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="bg-[#ed7c00] text-white font-semibold text-[18px] font-['Inter'] rounded-[8px] py-[14px] px-[30px] w-full border border-transparent hover:bg-[#d66a00] transition-colors duration-300 mt-4"
            >
              Talk to our Experts
            </button>

            <div
              id="form-message"
              class="text-white text-sm font-['Inter'] hidden"
            >
            </div>
          </form>
        </div>

        <!-- Thank You Message for Right Side -->
        <div
          id="thank-you-message-right"
          class="hidden flex-col gap-6 items-center text-center justify-center h-full"
        >
          <div class="flex items-center justify-center mb-4">
            <svg
              class="w-16 h-16 text-white"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="flex flex-col gap-4">
            <h3
              class="text-[32px] sm:text-[36px] lg:text-[40px] font-bold leading-tight text-white font-['Inter']"
            >
              Thank you!
            </h3>
            <p
              class="text-[16px] lg:text-[18px] font-normal leading-relaxed text-white/90 font-['Inter'] max-w-[400px]"
            >
              Your form has been successfully submitted.<br />
              Our team will get back to you shortly.
            </p>
          </div>
          <button
            id="submit-another-right"
            class="bg-[#ed7c00] text-white font-semibold text-[18px] font-['Inter'] rounded-[8px] py-[12px] px-[30px] border border-transparent hover:bg-transparent hover:border-white hover:text-white hover:cursor-pointer transition duration-300"
          >
            Submit Another Message
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("DOMContentLoaded", () => {
    const ctaEl = document.querySelector(".cta");
    if (!ctaEl) return;

    gsap.from(ctaEl, {
      opacity: 0,
      y: 50,
      duration: 0.8,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ctaEl,
        start: "top 50%",
        once: true,
      },
    });

    // Helper to show custom toast
    const showToast = (message: string, type = "success") => {
      const toast = document.createElement("div");
      toast.textContent = message;

      const bgColor = type === "success" ? "#ed7c00" : "#ef4444";
      toast.style.cssText = `
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background-color: ${bgColor};
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        font-size: 16px;
        z-index: 9999;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      `;

      document.body.appendChild(toast);

      // Animate in
      requestAnimationFrame(() => {
        toast.style.transform = "translateX(-50%) translateY(0)";
      });

      // Remove after 3.5s
      setTimeout(() => {
        toast.style.transform = "translateX(-50%) translateY(100px)";
        setTimeout(() => toast.remove(), 300);
      }, 3500);
    };

    // Contact form submission - Handle both mobile and desktop forms
    const desktopForm = document.getElementById(
      "contact-form-submit",
    ) as HTMLFormElement | null;
    const mobileForm = document.getElementById(
      "contact-form-submit-mobile",
    ) as HTMLFormElement | null;

    function handleFormSubmit(form: HTMLFormElement | null) {
      if (!form) return;

      form.addEventListener("submit", async (e: Event) => {
        e.preventDefault();

        const formData = new FormData(form);
        const name = formData.get("name")?.toString().trim() || "";
        const email = formData.get("email")?.toString().trim() || "";
        const phone = formData.get("phone")?.toString().trim() || "";
        const subject = formData.get("subject")?.toString().trim() || "";
        // Some inputs use "company", we will safely include it if available
        const company = formData.get("company")?.toString().trim() || "";
        const message = formData.get("message")?.toString().trim() || "";

        // Validation
        if (!name || !email || !message) {
          showToast(
            "Please fill in the Name, Email, and Message fields.",
            "error",
          );
          return;
        }

        const submitButton = form.querySelector(
          "button[type='submit']",
        ) as HTMLButtonElement | null;
        const originalText = submitButton ? submitButton.textContent : "";
        const originalOpacity = submitButton ? submitButton.style.opacity : "1";
        const originalCursor = submitButton ? submitButton.style.cursor : "";

        // Update UI Button State
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = "Sending...";
          submitButton.style.opacity = "0.7";
          submitButton.style.cursor = "not-allowed";
        }

        const htmlBody = `
          <div style="font-family: Arial, sans-serif; max-w: 600px; margin: 0 auto;">
            <h2 style="color: #ed7c00;">New Contact Submission</h2>
            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
              <tbody>
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left; width: 35%;">Name</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${name}</td>
                </tr>
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left;">Email</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${email}</td>
                </tr>
                ${
                  phone
                    ? `
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left;">Phone Number</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${phone}</td>
                </tr>`
                    : ""
                }
                ${
                  company
                    ? `
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left;">Company</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${company}</td>
                </tr>`
                    : ""
                }
                ${
                  subject
                    ? `
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left;">Subject</th>
                  <td style="border: 1px solid #ddd; padding: 12px;">${subject}</td>
                </tr>`
                    : ""
                }
                <tr>
                  <th style="border: 1px solid #ddd; padding: 12px; background-color: #f9fafb; text-align: left; vertical-align: top;">Message</th>
                  <td style="border: 1px solid #ddd; padding: 12px; white-space: pre-wrap;">${message}</td>
                </tr>
              </tbody>
            </table>
          </div>
        `;

        const payload = {
          source: "Finkeepers Website Web App",
          htmlBody: htmlBody,
        };

        try {
          const response = await fetch(
            "https://script.google.com/macros/s/AKfycbxij8BcsGQ7-hN7qUHlYXE5CbJiFO16LkOrAEAwbon5tN1A_oCDOFH91ehZoVdFsRFQ/exec",
            {
              method: "POST",
              body: JSON.stringify(payload),
            },
          );

          if (!response.ok) {
            throw new Error("Failed to send submission");
          }

          // Reset form and show success
          form.reset();
          showToast("Thank you! Your message has been sent.", "success");
        } catch (error) {
          console.error("Submission Error:", error);
          showToast("Submission failed. Please try again later.", "error");
        } finally {
          // Restore UI Button State
          if (submitButton) {
            submitButton.disabled = false;
            if (originalText !== null) submitButton.textContent = originalText;
            submitButton.style.opacity = originalOpacity || "1";
            submitButton.style.cursor = originalCursor || "";
          }
        }
      });
    }

    // Initialize logic
    handleFormSubmit(desktopForm);
    handleFormSubmit(mobileForm);
  });
</script>
