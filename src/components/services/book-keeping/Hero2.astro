---
import HeroImage from "../../../assets/services/book-keeping/hero_2-new.png";
import HeroImage_2 from "../../../assets/services/book-keeping/hero_2-new.png";
---

<div class="bg-[#f5f7fa] pb-6 px-4 sm:px-6 lg:px-20 relative overflow-hidden">
  <div
    class="max-w-screen-xl mx-auto flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6 sm:gap-8 lg:gap-24 relative"
  >
    {/* Left Content Area */}
    <div
      class="flex flex-col items-start text-left gap-6 lg:gap-8 max-w-2xl lg:w-1/2 order-2 lg:order-1"
    >
      <h1
        class="text-[32px] sm:text-[42px] lg:text-[52px] font-bold leading-tight text-[#151515]"
      >
        Balancing Numbers with Precision
      </h1>
      <p
        class="text-[16px] sm:text-[18px] leading-[27px] text-[#797979] max-w-xl"
      >
        Simplified bookkeeping for US startups and small businesses. Finkeepers
        is at your service.
      </p>
      <button
        id="contact-scroll-btn"
        class="flex w-[220px] sm:w-[280px] h-[44px] sm:h-[50px] px-[15px] justify-center items-center bg-[#ed7c00] rounded-[8px] cursor-pointer border border-transparent hover:bg-transparent hover:border-[#ed7c00] text-white hover:text-[#ed7c00] transition duration-300 mb-5 sm:mb-0"
      >
        <span
          class="text-[13px] sm:text-[18px] font-semibold leading-[20px] sm:leading-[24px] whitespace-nowrap"
        >
          Book a Free Consultation
        </span>
      </button>
    </div>

    {/* Right Image and Overlapping Cards Area */}
    <div
      class="relative w-full lg:w-1/2 flex justify-center items-center h-[350px] sm:h-[450px] lg:h-[500px] mt-20 lg:mt-0 mb-[-80px] sm:mb-[-40px] lg:mb-0 order-1 lg:order-2 hero-image-container"
    >
      {/* Main Image */}
      <img
        src={HeroImage.src}
        alt="Business Woman with tablet and growth charts"
        class="absolute w-[70%] lg:w-[90%] h-[70%] lg:h-[90%] object-contain top-[10%] z-[50]"
        style=" left: 50%; margin-left: -35%; @media (min-width: 1024px) { left: calc(10% - 40px); margin-left: 0; }"
      />
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const contactBtn = document.getElementById("contact-scroll-btn");

    if (contactBtn) {
      contactBtn.addEventListener("click", function () {
        // First try to find contact-section
        let contactSection = document.getElementById("contact-section");

        // If not found, try alternative selectors
        if (!contactSection) {
          contactSection = document.querySelector('[id*="contact"]');
        }
        if (!contactSection) {
          contactSection = document.querySelector(".contact-section");
        }
        if (!contactSection) {
          contactSection = document.querySelector("footer");
        }

        if (contactSection) {
          const yOffset = -40; // 40px offset from the top
          const y =
            contactSection.getBoundingClientRect().top +
            window.pageYOffset +
            yOffset;
          window.scrollTo({ top: y, behavior: "smooth" });
        } else {
          // Fallback: scroll to bottom of page
          window.scrollTo({
            top: document.body.scrollHeight - window.innerHeight - 40,
            behavior: "smooth",
          });
        }
      });
    }
  });
</script>
