---
import Header5 from "../components/Header5.astro";
import Layout from "../layouts/Layout.astro";
import ContactResp from "../components/home/animated/ContactResp.astro";
import Accordian from "../components/pricing/Accordian.astro";
import PricingComp from "../components/pricing/Pricing4.astro";
import HeroResp from "../components/pricing/HeroResp.astro";
import Footer6 from "../components/Footer6.astro";
---

<Layout
  title="Finkeepers Pricing – Simple Plans for Financial Services"
  description="Check out our transparent pricing for bookkeeping, reporting, payroll, and CFO services, ensuring you get exactly what you need with no hidden costs."
  canonical="https://finkeepers.us/pricing"
>
  <Header5 />
  <div class="mb-20 mt-20"></div>
  <PricingComp />
  <HeroResp />
  <Accordian />
  <div class="mt-10">
    <ContactResp />
    <div class="relative z-0 -mt-[80px]">
      <Footer6 />
    </div>
  </div>
</Layout>
