---
import Header5 from "../components/Header5.astro";
import Layout from "../layouts/Layout.astro";
import Hero4 from "../components/home/animated/Hero4.astro";
import Second2Resp from "../components/home/Second2Resp.astro";
import BlogResp from "../components/home//animated/BlogResp.astro";
import ContactResp from "../components/home/animated/ContactResp.astro";
import Footer6 from "../components/Footer6.astro";
---

<Layout
  title="Finkeepers – Business Strategy, Branding, and Marketing Services"
  description="Finkeepers helps businesses grow with smart branding, marketing, web design, and strategy services. Clear plans, strong visuals, and support that moves your business forward."
  canonical="https://finkeepers.us/"
>
  <Header5 />
  <div class="mb-20 mt-20">
    <Hero4 />
  </div>

  <Second2Resp />

  <BlogResp />

  <div class="mt-10">
    <ContactResp />
    <div class="relative z-0 -mt-[80px]">
      <Footer6 />
    </div>
  </div>
</Layout>
