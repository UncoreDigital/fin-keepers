---
import Layout from "../layouts/Layout.astro";
import Footer4Resp from "../components/Footer4Resp.astro";

import HeroAbout2 from "../components/about/HeroAbout2.astro";
import HeroResp from "../components/about/HeroResp.astro";
import Vision5 from "../components/about/Vision5.astro";
import TeamResp from "../components/about/TeamResp.astro";
import Cta from "../components/about/Cta.astro";
import Blogs from "../components/about/Blogs.astro";
import Header5 from "../components/Header5.astro";
---

<Layout>
  <Header5 />
  <div class="bg-[#213d3c] w-full">
    <!-- Desktop version only (visible from lg and up) -->
    <div class="hidden lg:block">
      <HeroAbout2 />
    </div>

    <!-- Mobile/Tablet version only (visible below lg) -->
    <div class="block lg:hidden">
      <HeroResp />
    </div>
  </div>
  <div class="p-10">
    <Vision5 />
  </div>

  <TeamResp />
  <Blogs />

  <div class="mt-10">
    <Cta />
    <div class="relative z-0 -mt-[80px]">
      <Footer4Resp />
    </div>
  </div>
</Layout>
