---
import Layout from "../layouts/Layout.astro";
import Header5 from "../components/Header5.astro";
import Footer6 from "../components/Footer6.astro";
import ContactResp from "../components/home/animated/ContactResp.astro";
---

<Layout
  title="Careers at Finkeepers | Join Our Financial Experts Team"
  description="Explore career opportunities at Finkeepers. We are always looking for talented financial professionals to join our growing team serving startups and SMBs."
  canonical="https://finkeepers.us/careers"
>
  <Header5 />

  <div
    class="main-container w-full pt-[120px] pb-[80px] px-4 sm:px-6 lg:px-[120px] bg-[#f5f7fa] min-h-[60vh]"
  >
    <div
      class="max-w-[1200px] mx-auto flex flex-col gap-8 items-center text-center"
    >
      <h1
        class="text-[36px] sm:text-[48px] font-bold text-[#04092a] leading-tight"
      >
        Join the Finkeepers Team
      </h1>
      <p class="text-[18px] text-[#5c667a] max-w-2xl leading-relaxed">
        We are always looking for talented individuals who are passionate about
        finance and helping businesses grow. If you are a CPA, bookkeeper, or
        financial analyst looking to make an impact, we'd love to hear from you.
      </p>

      <div
        class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 max-w-3xl w-full mt-8"
      >
        <h2 class="text-2xl font-semibold text-[#151515] mb-4">
          Current Openings
        </h2>
        <p class="text-[#797979]">
          We are currently updating our open positions. Please check back soon
          or send your resume to <a
            href="mailto:careers@finkeepers.us"
            class="text-[#ed7c00] hover:underline">careers@finkeepers.us</a
          >.
        </p>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <ContactResp />
    <div class="relative z-0 -mt-[80px]">
      <Footer6 />
    </div>
  </div>
</Layout>
