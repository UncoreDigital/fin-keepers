---
import Layout from "../layouts/Layout.astro";
import Hero2 from "../components/about2/Hero2.astro";
import Vision3 from "../components/about2/Vision3.astro";
import Core3 from "../components/about2/Core3.astro";
import Team from "../components/about2/Team.astro";
import BlogResp from "../components/about2/BlogResp.astro";
import ContactResp from "../components/home/animated/ContactResp.astro";
import Footer6 from "../components/Footer6.astro";
import Header5 from "../components/Header5.astro";
---

<Layout
  title="Finkeepers – Who We Are and How We Support Your Business"
  description="Learn about the Finkeepers team and how we support businesses with clear financial processes, steady guidance, and expert management of your finances."
  canonical="https://finkeepers.us/about"
>
  <Header5 />
  <div class="mt-20"><Hero2 /></div>
  <Vision3 />
  <Core3 />
  <Team />
  <BlogResp />
  <div class="mt-10">
    <ContactResp />
    <div class="relative z-0 -mt-[80px]">
      <Footer6 />
    </div>
  </div>
</Layout>
